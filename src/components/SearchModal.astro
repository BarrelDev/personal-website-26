---
import { getCollection } from 'astro:content';

// Build search index at compile time
const projects = await getCollection('projects');
const publications = await getCollection('publications');
const experiences = await getCollection('experience');
const blogPosts = await getCollection('blog');

const searchIndex = [
	...projects.map((p) => ({
		title: p.data.title,
		description: p.data.description,
		tags: p.data.tech.join(', '),
		category: p.data.category,
		type: 'project' as const,
		url: '/projects',
	})),
	...publications.map((p) => ({
		title: p.data.title,
		description: p.data.abstract,
		tags: p.data.venue,
		category: 'publication',
		type: 'publication' as const,
		url: '/research',
	})),
	...experiences.map((e) => ({
		title: `${e.data.title} at ${e.data.organization}`,
		description: e.data.description,
		tags: e.data.tech?.join(', ') ?? '',
		category: 'experience',
		type: 'experience' as const,
		url: '/cv',
	})),
	...blogPosts.map((b) => ({
		title: b.data.title,
		description: b.data.description,
		tags: '',
		category: 'blog',
		type: 'blog' as const,
		url: `/blog/${b.id}/`,
	})),
];

const typeIcons: Record<string, string> = {
	project: 'P',
	publication: 'R',
	experience: 'E',
	blog: 'B',
};

const typeColors: Record<string, string> = {
	project: 'bg-purple-500/20 text-purple-400',
	publication: 'bg-cyan-500/20 text-cyan-400',
	experience: 'bg-green-500/20 text-green-400',
	blog: 'bg-orange-500/20 text-orange-400',
};
---

<!-- Search Modal Backdrop -->
<div
	id="search-modal"
	class="fixed inset-0 z-[100] hidden items-start justify-center pt-[15vh] px-4"
	role="dialog"
	aria-modal="true"
	aria-label="Search"
>
	<!-- Backdrop -->
	<div id="search-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

	<!-- Modal -->
	<div
		class="relative w-full max-w-2xl bg-white dark:bg-dark-card rounded-xl shadow-2xl border border-gray-200 dark:border-gray-700 overflow-hidden"
	>
		<!-- Search Input -->
		<div class="flex items-center gap-3 px-4 py-3 border-b border-gray-200 dark:border-gray-700">
			<svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="2"
					d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
			</svg>
			<input
				id="search-input"
				type="text"
				placeholder="Search projects, publications, experience..."
				class="flex-1 bg-transparent text-gray-900 dark:text-white placeholder-gray-400 outline-none text-lg"
				autocomplete="off"
			/>
			<kbd
				class="hidden sm:inline-block px-2 py-0.5 text-xs text-gray-400 bg-gray-100 dark:bg-gray-800 rounded border border-gray-200 dark:border-gray-700"
				>Esc</kbd
			>
		</div>

		<!-- Results -->
		<div id="search-results" class="max-h-[50vh] overflow-y-auto p-2">
			<!-- Default: show all items grouped -->
			<div id="search-default" class="space-y-1">
				<p class="px-3 py-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">Quick Links</p>
				<a
					href="/"
					class="search-result flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
					data-index="0"
				>
					<span class="text-sm">Home</span>
				</a>
				<a
					href="/projects"
					class="search-result flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
					data-index="1"
				>
					<span class="text-sm">Projects</span>
				</a>
				<a
					href="/research"
					class="search-result flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
					data-index="2"
				>
					<span class="text-sm">Research</span>
				</a>
				<a
					href="/cv"
					class="search-result flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
					data-index="3"
				>
					<span class="text-sm">CV</span>
				</a>
				<a
					href="/blog"
					class="search-result flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
					data-index="4"
				>
					<span class="text-sm">Blog</span>
				</a>
				<a
					href="/about"
					class="search-result flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
					data-index="5"
				>
					<span class="text-sm">About</span>
				</a>
			</div>

			<!-- Filtered results (hidden by default) -->
			<div id="search-filtered" class="hidden space-y-1"></div>

			<!-- No results -->
			<div id="search-empty" class="hidden px-3 py-8 text-center text-gray-400">
				<p>No results found</p>
			</div>
		</div>

		<!-- Footer -->
		<div
			class="flex items-center gap-4 px-4 py-2 border-t border-gray-200 dark:border-gray-700 text-xs text-gray-400"
		>
			<span class="flex items-center gap-1">
				<kbd class="px-1.5 py-0.5 bg-gray-100 dark:bg-gray-800 rounded border border-gray-200 dark:border-gray-700"
					>&uarr;</kbd
				>
				<kbd class="px-1.5 py-0.5 bg-gray-100 dark:bg-gray-800 rounded border border-gray-200 dark:border-gray-700"
					>&darr;</kbd
				>
				navigate
			</span>
			<span class="flex items-center gap-1">
				<kbd
					class="px-1.5 py-0.5 bg-gray-100 dark:bg-gray-800 rounded border border-gray-200 dark:border-gray-700"
					>&crarr;</kbd
				>
				open
			</span>
			<span class="flex items-center gap-1">
				<kbd
					class="px-1.5 py-0.5 bg-gray-100 dark:bg-gray-800 rounded border border-gray-200 dark:border-gray-700"
					>esc</kbd
				>
				close
			</span>
		</div>
	</div>
</div>

<!-- Pass search index to client -->
<script is:inline define:vars={{ searchIndex, typeIcons, typeColors }}>
	window.__searchIndex = searchIndex;
	window.__typeIcons = typeIcons;
	window.__typeColors = typeColors;
</script>

<script>
	function setupSearch() {
		const modal = document.getElementById('search-modal');
		const backdrop = document.getElementById('search-backdrop');
		const input = document.getElementById('search-input') as HTMLInputElement;
		const defaultResults = document.getElementById('search-default');
		const filteredResults = document.getElementById('search-filtered');
		const emptyResults = document.getElementById('search-empty');

		if (!modal || !input || !defaultResults || !filteredResults || !emptyResults) return;

		const searchIndex = (window as any).__searchIndex as Array<{
			title: string;
			description: string;
			tags: string;
			category: string;
			type: string;
			url: string;
		}>;
		const typeIcons = (window as any).__typeIcons as Record<string, string>;
		const typeColors = (window as any).__typeColors as Record<string, string>;

		let selectedIndex = -1;

		function openModal() {
			modal.classList.remove('hidden');
			modal.classList.add('flex');
			input.value = '';
			input.focus();
			selectedIndex = -1;
			showDefault();
			document.body.style.overflow = 'hidden';
		}

		function closeModal() {
			modal.classList.add('hidden');
			modal.classList.remove('flex');
			document.body.style.overflow = '';
		}

		function showDefault() {
			defaultResults.classList.remove('hidden');
			filteredResults.classList.add('hidden');
			emptyResults.classList.add('hidden');
			selectedIndex = -1;
			updateSelection();
		}

		function updateSelection() {
			const results = modal.querySelectorAll('.search-result');
			results.forEach((r, i) => {
				if (i === selectedIndex) {
					r.classList.add('bg-gray-100', 'dark:bg-gray-800');
				} else {
					r.classList.remove('bg-gray-100', 'dark:bg-gray-800');
				}
			});
			// Scroll selected into view
			if (selectedIndex >= 0 && results[selectedIndex]) {
				results[selectedIndex].scrollIntoView({ block: 'nearest' });
			}
		}

		function search(query: string) {
			if (!query.trim()) {
				showDefault();
				return;
			}

			const q = query.toLowerCase();
			const matches = searchIndex.filter(
				(item) =>
					item.title.toLowerCase().includes(q) ||
					item.description.toLowerCase().includes(q) ||
					item.tags.toLowerCase().includes(q) ||
					item.category.toLowerCase().includes(q) ||
					item.type.toLowerCase().includes(q),
			);

			defaultResults.classList.add('hidden');

			if (matches.length === 0) {
				filteredResults.classList.add('hidden');
				emptyResults.classList.remove('hidden');
				selectedIndex = -1;
				return;
			}

			emptyResults.classList.add('hidden');
			filteredResults.classList.remove('hidden');

			filteredResults.innerHTML = matches
				.map(
					(item, i) => `
				<a href="${item.url}" class="search-result flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" data-index="${i}">
					<span class="flex-shrink-0 w-7 h-7 rounded-md flex items-center justify-center text-xs font-bold ${typeColors[item.type] || ''}">${typeIcons[item.type] || '?'}</span>
					<div class="flex-1 min-w-0">
						<div class="text-sm font-medium text-gray-900 dark:text-white truncate">${item.title}</div>
						<div class="text-xs text-gray-400 truncate">${item.description.slice(0, 80)}${item.description.length > 80 ? '...' : ''}</div>
					</div>
					<span class="flex-shrink-0 text-xs text-gray-400 capitalize">${item.type}</span>
				</a>
			`,
				)
				.join('');

			selectedIndex = 0;
			updateSelection();
		}

		// Input handler
		input.addEventListener('input', () => search(input.value));

		// Keyboard shortcuts
		document.addEventListener('keydown', (e) => {
			// Open with Ctrl+K or /
			if ((e.key === 'k' && (e.metaKey || e.ctrlKey)) || (e.key === '/' && !isInputFocused())) {
				e.preventDefault();
				if (modal.classList.contains('hidden')) {
					openModal();
				} else {
					closeModal();
				}
				return;
			}

			// Only handle other keys when modal is open
			if (modal.classList.contains('hidden')) return;

			if (e.key === 'Escape') {
				e.preventDefault();
				closeModal();
			} else if (e.key === 'ArrowDown') {
				e.preventDefault();
				const results = modal.querySelectorAll('.search-result');
				if (results.length > 0) {
					selectedIndex = (selectedIndex + 1) % results.length;
					updateSelection();
				}
			} else if (e.key === 'ArrowUp') {
				e.preventDefault();
				const results = modal.querySelectorAll('.search-result');
				if (results.length > 0) {
					selectedIndex = selectedIndex <= 0 ? results.length - 1 : selectedIndex - 1;
					updateSelection();
				}
			} else if (e.key === 'Enter') {
				e.preventDefault();
				const results = modal.querySelectorAll('.search-result');
				if (selectedIndex >= 0 && results[selectedIndex]) {
					(results[selectedIndex] as HTMLAnchorElement).click();
					closeModal();
				}
			}
		});

		// Close on backdrop click
		backdrop?.addEventListener('click', closeModal);

		function isInputFocused() {
			const active = document.activeElement;
			return (
				active instanceof HTMLInputElement ||
				active instanceof HTMLTextAreaElement ||
				active?.getAttribute('contenteditable') === 'true'
			);
		}
	}

	setupSearch();
	document.addEventListener('astro:page-load', setupSearch);
</script>
