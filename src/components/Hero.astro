---
import { Image } from 'astro:assets';
import profileImg from '../assets/profile/profile-main.jpg';
import profileData from '../data/profile.json';
import { SOCIAL_LINKS, HERO } from '../consts';
---

<section class="relative min-h-[calc(100vh-80px)] flex items-center justify-center overflow-hidden">
	<!-- Background gradient -->
	<div
		class="absolute inset-0 bg-gradient-to-br from-brand-blue/10 via-transparent to-brand-blue-light/10 dark:from-brand-blue/5 dark:to-brand-blue-light/5"
	>
	</div>

	<!-- Content -->
	<div class="container mx-auto px-4 py-20 relative z-10">
		<div class="grid md:grid-cols-2 gap-12 items-center">
			<!-- Text Content -->
			<div class="space-y-6 animate-fade-up">
				<h1 class="text-5xl md:text-6xl font-bold dark:text-white">
					{HERO.greeting} <span class="text-brand-blue">{profileData.name}</span>
				</h1>

				<div class="text-2xl md:text-3xl dark:text-gray-300">
					{HERO.intro} <span id="typed-text" class="text-brand-blue font-semibold"></span><span
						id="typed-cursor"
						class="text-brand-blue animate-pulse">|</span
					>
				</div>

				<p class="text-lg dark:text-gray-400 max-w-xl">
					{profileData.bio}
				</p>

				<!-- CTA Buttons -->
				<div class="flex flex-wrap gap-4 pt-4">
					<a
						href="/projects"
						class="px-6 py-3 bg-brand-blue text-white rounded-lg hover:bg-brand-blue-light transition-all hover:scale-105 shadow-lg"
					>
						{HERO.ctaProjects}
					</a>
					<a
						href="/docs/visvam-rajesh-resume.pdf"
						download
						class="px-6 py-3 border-2 border-brand-blue text-brand-blue rounded-lg hover:bg-brand-blue hover:text-white transition-all"
					>
						{HERO.ctaResume}
					</a>
				</div>

				<!-- Social Links -->
				<div class="flex gap-4 pt-4">
					<a
						href={SOCIAL_LINKS.github}
						target="_blank"
						rel="noopener noreferrer"
						class="social-icon text-gray-600 dark:text-gray-400"
						aria-label="GitHub"
					>
						<svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
							<path
								d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
							></path>
						</svg>
					</a>
					<a
						href={SOCIAL_LINKS.linkedin}
						target="_blank"
						rel="noopener noreferrer"
						class="social-icon text-gray-600 dark:text-gray-400"
						aria-label="LinkedIn"
					>
						<svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
							<path
								d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
							></path>
						</svg>
					</a>
					<a
						href={`mailto:${SOCIAL_LINKS.email}`}
						class="social-icon text-gray-600 dark:text-gray-400"
						aria-label="Email"
					>
						<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
							></path>
						</svg>
					</a>
				</div>
			</div>

			<!-- Profile Image -->
			<div class="relative animate-fade-in hidden md:block">
				<div class="relative w-full max-w-md mx-auto">
					<!-- Decorative glow -->
					<div
						class="absolute -inset-4 bg-gradient-to-r from-brand-blue to-brand-blue-light rounded-2xl opacity-20 blur-2xl"
					>
					</div>

					<!-- Image -->
					<Image
						src={profileImg}
						alt={profileData.name}
						width={500}
						height={625}
						class="relative rounded-3xl border-4 border-brand-blue/50 shadow-2xl object-cover aspect-[4/5]"
					/>
				</div>
			</div>
		</div>
	</div>

	<!-- Scroll indicator -->
	<div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
		<svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"
			></path>
		</svg>
	</div>
</section>

<!-- Pass roles to client -->
<script is:inline define:vars={{ roles: profileData.roles }}>
	window.__typedRoles = roles;
</script>

<!-- Typed.js initialization -->
<script>
	import Typed from 'typed.js';

	let typedInstance: Typed | null = null;

	function initTyped() {
		const el = document.getElementById('typed-text');
		const cursor = document.getElementById('typed-cursor');
		if (!el) return;

		// Destroy previous instance to prevent duplicate cursors
		if (typedInstance) {
			typedInstance.destroy();
			typedInstance = null;
		}

		// Hide the static fallback cursor
		if (cursor) cursor.style.display = 'none';

		// Clear any leftover content/cursors from previous instances
		el.textContent = '';

		const roles = (window as any).__typedRoles || ['Developer'];

		typedInstance = new Typed('#typed-text', {
			strings: roles,
			typeSpeed: 50,
			backSpeed: 30,
			backDelay: 2000,
			loop: true,
			showCursor: true,
			cursorChar: '|',
		});
	}

	initTyped();
	document.addEventListener('astro:page-load', initTyped);
</script>

<style>
	.social-icon {
		display: inline-block;
		transition:
			transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
			color 0.2s ease,
			filter 0.2s ease;
	}
	.social-icon:hover {
		color: #1e90ff;
		transform: scale(1.2);
		filter: brightness(1.3) drop-shadow(0 0 6px rgba(30, 144, 255, 0.4));
	}
	.social-icon:active {
		transform: scale(1.1);
	}
</style>
