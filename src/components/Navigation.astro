---
import { NAV_LINKS } from '../consts';
import { Image } from 'astro:assets';
import logo from '../assets/logos/vr-logo-transparent.png';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/80 dark:bg-dark-card/80 backdrop-blur-md border-b border-gray-200 dark:border-gray-800 transition-colors">
	<nav class="container mx-auto px-4 py-4">
		<div class="flex items-center justify-between">
			<!-- Logo -->
			<a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
				<Image src={logo} alt="VR" width={40} height={40} />
			</a>

			<!-- Desktop Navigation -->
			<ul class="hidden md:flex items-center gap-6">
				{
					NAV_LINKS.map((link) => (
						<li>
							<a
								href={link.href}
								data-nav-link
								class={`px-3 py-2 rounded-lg transition-all hover:bg-brand-blue/10 hover:text-brand-blue ${
									currentPath === link.href
										? 'text-brand-blue font-semibold border-b-2 border-brand-blue'
										: 'dark:text-gray-300'
								}`}
							>
								{link.label}
							</a>
						</li>
					))
				}
			</ul>

			<!-- Desktop Search + Dark Mode -->
			<div class="hidden md:flex items-center gap-2">
				<button
					id="search-trigger"
					class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors text-sm text-gray-500 dark:text-gray-400"
					aria-label="Search"
				>
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
					</svg>
					<span class="hidden lg:inline">Search</span>
					<kbd class="hidden lg:inline-block px-1.5 py-0.5 text-xs bg-gray-300 dark:bg-gray-600 rounded">Ctrl K</kbd>
				</button>
			<button
				id="theme-toggle"
				class="p-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors"
				aria-label="Toggle dark mode"
			>
				<svg id="theme-toggle-dark-icon" class="w-5 h-5 hidden dark:block" fill="currentColor" viewBox="0 0 20 20">
					<path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
				</svg>
				<svg id="theme-toggle-light-icon" class="w-5 h-5 block dark:hidden" fill="currentColor" viewBox="0 0 20 20">
					<path
						d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
					></path>
				</svg>
			</button>
			</div>

			<!-- Mobile Menu Button, Search, and Dark Mode Toggle -->
			<div class="flex md:hidden items-center gap-2">
				<button
					id="search-trigger-mobile"
					class="p-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors"
					aria-label="Search"
				>
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
					</svg>
				</button>
				<button
					id="theme-toggle-mobile"
					class="p-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors"
					aria-label="Toggle dark mode"
				>
					<svg class="w-5 h-5 hidden dark:block" fill="currentColor" viewBox="0 0 20 20">
						<path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
					</svg>
					<svg class="w-5 h-5 block dark:hidden" fill="currentColor" viewBox="0 0 20 20">
						<path
							d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
						></path>
					</svg>
				</button>
				<button id="mobile-menu-toggle" class="p-2" aria-label="Toggle menu">
					<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
						<path
							fill-rule="evenodd"
							d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z"
							clip-rule="evenodd"></path>
					</svg>
				</button>
			</div>
		</div>

		<!-- Mobile Menu -->
		<div id="mobile-menu" class="hidden md:hidden mt-4 pb-4">
			<ul class="flex flex-col gap-2">
				{
					NAV_LINKS.map((link) => (
						<li>
							<a
								href={link.href}
								data-nav-link-mobile
								class={`block px-4 py-2 rounded-lg transition-all hover:bg-brand-blue/10 hover:text-brand-blue ${
									currentPath === link.href
										? 'bg-brand-blue/20 text-brand-blue font-semibold'
										: 'dark:text-gray-300'
								}`}
							>
								{link.label}
							</a>
						</li>
					))
				}
			</ul>
		</div>
	</nav>
</header>

<script>
	// Dark mode toggle functionality
	function setupThemeToggle() {
		const toggle = document.getElementById('theme-toggle');
		const toggleMobile = document.getElementById('theme-toggle-mobile');
		const html = document.documentElement;

		const handleToggle = () => {
			const isDark = html.classList.toggle('dark');
			localStorage.setItem('theme', isDark ? 'dark' : 'light');
		};

		toggle?.addEventListener('click', handleToggle);
		toggleMobile?.addEventListener('click', handleToggle);
	}

	// Mobile menu toggle
	function setupMobileMenu() {
		const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
		const mobileMenu = document.getElementById('mobile-menu');

		mobileMenuToggle?.addEventListener('click', () => {
			mobileMenu?.classList.toggle('hidden');
		});
	}

	// Search trigger buttons
	function setupSearchTriggers() {
		const openSearch = () => {
			const modal = document.getElementById('search-modal');
			const input = document.getElementById('search-input') as HTMLInputElement;
			if (modal) {
				modal.classList.remove('hidden');
				modal.classList.add('flex');
				input?.focus();
				document.body.style.overflow = 'hidden';
			}
		};

		document.getElementById('search-trigger')?.addEventListener('click', openSearch);
		document.getElementById('search-trigger-mobile')?.addEventListener('click', openSearch);
	}

	// Update active nav link to match current URL
	function updateActiveLink() {
		const path = window.location.pathname;
		document.querySelectorAll('[data-nav-link]').forEach((link) => {
			const href = link.getAttribute('href') || '';
			const isActive = href === '/' ? path === '/' : path.startsWith(href);
			if (isActive) {
				link.classList.add('text-brand-blue', 'font-semibold', 'border-b-2', 'border-brand-blue');
				link.classList.remove('dark:text-gray-300');
			} else {
				link.classList.remove('text-brand-blue', 'font-semibold', 'border-b-2', 'border-brand-blue');
				link.classList.add('dark:text-gray-300');
			}
		});
		// Also update mobile menu links
		document.querySelectorAll('[data-nav-link-mobile]').forEach((link) => {
			const href = link.getAttribute('href') || '';
			const isActive = href === '/' ? path === '/' : path.startsWith(href);
			if (isActive) {
				link.classList.add('bg-brand-blue/20', 'text-brand-blue', 'font-semibold');
				link.classList.remove('dark:text-gray-300');
			} else {
				link.classList.remove('bg-brand-blue/20', 'text-brand-blue', 'font-semibold');
				link.classList.add('dark:text-gray-300');
			}
		});
	}

	// Initialize on page load
	setupThemeToggle();
	setupMobileMenu();
	setupSearchTriggers();
	updateActiveLink();

	// Re-initialize after page transitions
	document.addEventListener('astro:page-load', () => {
		setupThemeToggle();
		setupMobileMenu();
		setupSearchTriggers();
		updateActiveLink();
	});
</script>
