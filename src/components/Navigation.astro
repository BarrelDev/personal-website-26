---
import { NAV_LINKS } from '../consts';
import { Image } from 'astro:assets';
import logo from '../assets/logos/vr-logo-transparent.png';

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-gray-50/80 dark:bg-dark-bg/80 backdrop-blur-md border-b border-gray-200 dark:border-dark-border transition-colors">
	<nav class="container mx-auto px-4 py-4">
		<div class="flex items-center justify-between">
			<!-- Logo -->
			<a href="/personal-website-26/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
				<Image src={logo} alt="VR" width={40} height={40} class="dark:invert-0 invert" />
			</a>

			<!-- Desktop Navigation -->
			<ul class="hidden md:flex items-center gap-6">
				{
					NAV_LINKS.map((link) => (
						<li>
							<a
								href={link.href}
								data-nav-link
								class={`px-3 py-2 rounded-lg transition-all hover:bg-brand-blue/10 hover:text-brand-blue ${
									currentPath === link.href
										? 'text-brand-blue font-semibold border-b-2 border-brand-blue'
										: 'dark:text-gray-300'
								}`}
							>
								{link.label}
							</a>
						</li>
					))
				}
			</ul>

			<!-- Desktop Search + Dark Mode -->
			<div class="hidden md:flex items-center gap-2">
				<button
					id="search-trigger"
					class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-gray-200 dark:bg-dark-surface hover:bg-gray-300 dark:hover:bg-dark-border transition-colors text-sm text-gray-500 dark:text-gray-400"
					aria-label="Search"
				>
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
					</svg>
					<span class="hidden lg:inline">Search</span>
					<kbd class="hidden lg:inline-block px-1.5 py-0.5 text-xs bg-gray-300 dark:bg-gray-600 rounded">Ctrl K or /</kbd>
				</button>
			<button
				id="theme-toggle"
				class="p-2 rounded-lg bg-gray-200 dark:bg-dark-surface hover:bg-gray-300 dark:hover:bg-dark-border transition-colors"
				aria-label="Toggle dark mode"
			>
				<svg id="theme-toggle-dark-icon" class="w-5 h-5 hidden dark:block" fill="currentColor" viewBox="0 0 20 20">
					<path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
				</svg>
				<svg id="theme-toggle-light-icon" class="w-5 h-5 block dark:hidden" fill="currentColor" viewBox="0 0 20 20">
					<path
						d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
					></path>
				</svg>
			</button>
			</div>

			<!-- Mobile Menu Button, Search, and Dark Mode Toggle -->
			<div class="flex md:hidden items-center gap-2">
				<button
					id="search-trigger-mobile"
					class="p-2 rounded-lg bg-gray-200 dark:bg-dark-surface hover:bg-gray-300 dark:hover:bg-dark-border transition-colors"
					aria-label="Search"
				>
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
					</svg>
				</button>
				<button
					id="theme-toggle-mobile"
					class="p-2 rounded-lg bg-gray-200 dark:bg-dark-surface hover:bg-gray-300 dark:hover:bg-dark-border transition-colors"
					aria-label="Toggle dark mode"
				>
					<svg class="w-5 h-5 hidden dark:block" fill="currentColor" viewBox="0 0 20 20">
						<path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
					</svg>
					<svg class="w-5 h-5 block dark:hidden" fill="currentColor" viewBox="0 0 20 20">
						<path
							d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
						></path>
					</svg>
				</button>
				<button id="mobile-menu-toggle" class="p-2 relative w-10 h-10" aria-label="Toggle menu">
					<span class="hamburger-line top-[11px]"></span>
					<span class="hamburger-line top-[17px]"></span>
					<span class="hamburger-line top-[23px]"></span>
				</button>
			</div>
		</div>

		<!-- Mobile Menu -->
		<div
			id="mobile-menu"
			class="md:hidden overflow-hidden transition-all duration-300 ease-out"
			style="max-height: 0; opacity: 0;"
		>
			<ul class="flex flex-col gap-1 pt-4 pb-2">
				{
					NAV_LINKS.map((link, i) => (
						<li
							class="mobile-menu-item"
							style={`transition-delay: ${i * 40}ms;`}
						>
							<a
								href={link.href}
								data-nav-link-mobile
								class={`block px-4 py-2 rounded-lg transition-all hover:bg-brand-blue/10 hover:text-brand-blue ${
									currentPath === link.href
										? 'bg-brand-blue/20 text-brand-blue font-semibold'
										: 'dark:text-gray-300'
								}`}
							>
								{link.label}
							</a>
						</li>
					))
				}
			</ul>
		</div>
	</nav>
</header>

<script>
	// Dark mode toggle functionality
	function setupThemeToggle() {
		const html = document.documentElement;
		const handleToggle = () => {
			const isDark = html.classList.toggle('dark');
			localStorage.setItem('theme', isDark ? 'dark' : 'light');
		};

		// Clone and replace to avoid stacking listeners on persisted nav
		['theme-toggle', 'theme-toggle-mobile'].forEach((id) => {
			const el = document.getElementById(id);
			if (!el) return;
			const fresh = el.cloneNode(true) as HTMLElement;
			el.parentNode?.replaceChild(fresh, el);
			fresh.addEventListener('click', handleToggle);
		});
	}

	// Mobile menu toggle with animation
	function setupMobileMenu() {
		const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
		const mobileMenu = document.getElementById('mobile-menu');
		if (!mobileMenuToggle || !mobileMenu) return;

		let isOpen = false;

		function openMenu() {
			isOpen = true;
			mobileMenuToggle!.classList.add('menu-open');
			mobileMenu!.style.maxHeight = mobileMenu!.scrollHeight + 'px';
			mobileMenu!.style.opacity = '1';
			// Stagger menu items
			mobileMenu!.querySelectorAll('.mobile-menu-item').forEach((item) => {
				(item as HTMLElement).classList.add('revealed');
			});
		}

		function closeMenu() {
			isOpen = false;
			mobileMenuToggle!.classList.remove('menu-open');
			mobileMenu!.style.maxHeight = '0';
			mobileMenu!.style.opacity = '0';
			mobileMenu!.querySelectorAll('.mobile-menu-item').forEach((item) => {
				(item as HTMLElement).classList.remove('revealed');
			});
		}

		// Clone and replace to strip any existing listeners
		const freshBtn = mobileMenuToggle.cloneNode(true) as HTMLElement;
		mobileMenuToggle.parentNode?.replaceChild(freshBtn, mobileMenuToggle);

		freshBtn.addEventListener('click', () => {
			if (isOpen) closeMenu();
			else openMenu();
		});

		// Close mobile menu when a link is clicked
		mobileMenu.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', () => closeMenu());
		});
	}

	// Search trigger buttons
	function setupSearchTriggers() {
		const openSearch = () => {
			const modal = document.getElementById('search-modal');
			const input = document.getElementById('search-input') as HTMLInputElement;
			if (modal) {
				modal.classList.remove('hidden');
				modal.classList.add('flex');
				input?.focus();
				document.body.style.overflow = 'hidden';
			}
		};

		// Clone and replace to avoid stacking listeners on persisted nav
		['search-trigger', 'search-trigger-mobile'].forEach((id) => {
			const el = document.getElementById(id);
			if (!el) return;
			const fresh = el.cloneNode(true) as HTMLElement;
			el.parentNode?.replaceChild(fresh, el);
			fresh.addEventListener('click', openSearch);
		});
	}

	// Update active nav link to match current URL
	function updateActiveLink() {
		const path = window.location.pathname;
		document.querySelectorAll('[data-nav-link]').forEach((link) => {
			const href = link.getAttribute('href') || '';
			const isActive = href === '/' ? path === '/' : path.startsWith(href);
			if (isActive) {
				link.classList.add('text-brand-blue', 'font-semibold', 'border-b-2', 'border-brand-blue');
				link.classList.remove('dark:text-gray-300');
			} else {
				link.classList.remove('text-brand-blue', 'font-semibold', 'border-b-2', 'border-brand-blue');
				link.classList.add('dark:text-gray-300');
			}
		});
		// Also update mobile menu links
		document.querySelectorAll('[data-nav-link-mobile]').forEach((link) => {
			const href = link.getAttribute('href') || '';
			const isActive = href === '/' ? path === '/' : path.startsWith(href);
			if (isActive) {
				link.classList.add('bg-brand-blue/20', 'text-brand-blue', 'font-semibold');
				link.classList.remove('dark:text-gray-300');
			} else {
				link.classList.remove('bg-brand-blue/20', 'text-brand-blue', 'font-semibold');
				link.classList.add('dark:text-gray-300');
			}
		});
	}

	// Initialize on page load
	setupThemeToggle();
	setupMobileMenu();
	setupSearchTriggers();
	updateActiveLink();

	// Re-initialize after page transitions
	document.addEventListener('astro:page-load', () => {
		setupThemeToggle();
		setupMobileMenu();
		setupSearchTriggers();
		updateActiveLink();
	});
</script>

<style>
	/* Hamburger lines → X morphing */
	.hamburger-line {
		position: absolute;
		left: 8px;
		width: 20px;
		height: 2px;
		border-radius: 1px;
		transition:
			transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
			opacity 0.2s ease,
			top 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
		@apply bg-gray-700 dark:bg-gray-300;
	}

	.menu-open .hamburger-line:nth-child(1) {
		top: 17px;
		transform: rotate(45deg);
	}

	.menu-open .hamburger-line:nth-child(2) {
		opacity: 0;
	}

	.menu-open .hamburger-line:nth-child(3) {
		top: 17px;
		transform: rotate(-45deg);
	}

	/* Menu items stagger fade in */
	.mobile-menu-item {
		opacity: 0;
		transform: translateX(-12px);
		transition:
			opacity 0.25s ease-out,
			transform 0.25s ease-out;
	}

	.mobile-menu-item.revealed {
		opacity: 1;
		transform: translateX(0);
	}
</style>
