---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PublicationCard from '../components/PublicationCard.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION, SOCIAL_LINKS } from '../consts';

// Fetch content
const projects = await getCollection('projects');
const featuredProjects = projects
	.filter((p) => p.data.featured)
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
	.slice(0, 3);

const publications = await getCollection('publications');
const latestPub = publications.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];

const experiences = await getCollection('experience');
const currentExperiences = experiences.filter((e) => e.data.current);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<!-- Hero Section -->
	<Hero />

	<!-- Featured Projects Section -->
	<section class="py-20 bg-gray-50 dark:bg-dark-bg/50">
		<div class="container mx-auto px-4">
			<div class="text-center mb-12" data-reveal>
				<h2 class="text-4xl font-bold dark:text-white mb-4">Featured Projects</h2>
				<p class="text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
					Here are some of my recent projects spanning robotics, machine learning, and software development.
				</p>
			</div>

			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
				{
					featuredProjects.map((project, i) => (
						<div data-reveal data-reveal-delay={i + 1}>
							<ProjectCard
								title={project.data.title}
								description={project.data.description}
								image={project.data.image}
								category={project.data.category}
								tags={project.data.tech}
								github={project.data.github}
								demo={project.data.demo}
								featured={true}
							/>
						</div>
					))
				}
			</div>

			<div class="text-center mt-12" data-reveal>
				<a
					href="/projects"
					class="inline-block px-8 py-3 bg-brand-blue text-white rounded-lg hover:bg-brand-blue-light transition-all hover:scale-105 shadow-lg"
				>
					View All Projects &rarr;
				</a>
			</div>
		</div>
	</section>

	<!-- Latest Publication Section -->
	{
		latestPub && (
			<section class="py-20">
				<div class="container mx-auto px-4">
					<div class="text-center mb-12" data-reveal>
						<h2 class="text-4xl font-bold dark:text-white mb-4">Latest Research</h2>
						<p class="text-gray-600 dark:text-gray-400">
							My recent publication in pathfinding algorithms
						</p>
					</div>

					<div class="max-w-4xl mx-auto" data-reveal>
						<PublicationCard
							title={latestPub.data.title}
							authors={latestPub.data.authors}
							venue={latestPub.data.venue}
							date={latestPub.data.date}
							abstract={latestPub.data.abstract}
							pdf={latestPub.data.pdf}
							doi={latestPub.data.doi}
							citation={latestPub.data.citation}
						/>
					</div>

					<div class="text-center mt-8">
						<a href="/research" class="inline-block text-brand-blue hover:underline font-semibold">
							View Research Page &rarr;
						</a>
					</div>
				</div>
			</section>
		)
	}

	<!-- Current Activities Section -->
	{
		currentExperiences.length > 0 && (
			<section class="py-20 bg-gray-50 dark:bg-dark-bg/50">
				<div class="container mx-auto px-4">
					<div class="text-center mb-12" data-reveal>
						<h2 class="text-4xl font-bold dark:text-white mb-4">What I'm Doing Now</h2>
					</div>

					<div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
						{currentExperiences.map((exp, i) => (
							<div data-reveal data-reveal-delay={i + 1} class="bg-white dark:bg-dark-card rounded-xl p-6 shadow-lg border border-gray-200 dark:border-gray-800">
								<h3 class="text-xl font-bold dark:text-white mb-2">{exp.data.title}</h3>
								<p class="text-brand-blue font-semibold mb-3">{exp.data.organization}</p>
								<p class="text-gray-600 dark:text-gray-400 text-sm">{exp.data.description}</p>
								{exp.data.tech && (
									<div class="flex flex-wrap gap-2 mt-4">
										{exp.data.tech.map((t) => (
											<span class="px-2 py-1 text-xs bg-gray-100 dark:bg-gray-800 rounded text-gray-600 dark:text-gray-400">
												{t}
											</span>
										))}
									</div>
								)}
							</div>
						))}
					</div>
				</div>
			</section>
		)
	}

	<!-- CTA Section -->
	<!-- <section class="py-20">
		<div class="container mx-auto px-4">
			<div
				class="max-w-4xl mx-auto text-center bg-gradient-to-r from-brand-blue to-brand-blue-light rounded-2xl p-12 text-white shadow-2xl"
			>
				<h2 class="text-3xl md:text-4xl font-bold mb-4">Let's Work Together</h2>
				<p class="text-xl mb-8 opacity-90">
					I'm always open to discussing new projects, creative ideas, or opportunities.
				</p>
				<a
					href={`mailto:${SOCIAL_LINKS.email}`}
					class="inline-block px-8 py-3 bg-white text-brand-blue rounded-lg hover:bg-gray-100 transition-all hover:scale-105 shadow-lg font-semibold"
				>
					Get in Touch
				</a>
			</div>
		</div>
	</section> -->
</BaseLayout>
