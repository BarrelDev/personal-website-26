---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import profileImg from '../assets/profile/profile-main.jpg';
import profileData from '../data/profile.json';
import aboutData from '../data/about.json';
import { PAGES } from '../consts';
import fs from 'node:fs';

// Read about bio markdown — split into paragraphs for rendering
const bioMd = fs.readFileSync('src/content/pages/about.md', 'utf-8');
const bioParagraphs = bioMd.split('\n\n').filter((p) => p.trim());
---

<BaseLayout title={PAGES.about.title} description={PAGES.about.description}>
	<section class="py-20">
		<div class="container mx-auto px-4">
			<div class="max-w-4xl mx-auto">
				<!-- Profile Image & Bio -->
				<div class="grid md:grid-cols-5 gap-8 mb-12" data-reveal>
					<div class="md:col-span-2">
						<Image
							src={profileImg}
							alt={profileData.name}
							width={400}
							height={400}
							class="rounded-2xl shadow-2xl object-cover aspect-square w-full"
						/>
					</div>

					<div class="md:col-span-3 space-y-4 text-gray-700 dark:text-gray-300">
						{
							bioParagraphs.map((paragraph, i) => (
								<p class={i === 0 ? 'text-lg' : ''}>{paragraph}</p>
							))
						}
					</div>
				</div>

				<!-- Quick Facts -->
				<div class="grid md:grid-cols-3 gap-6 mb-12" data-reveal>
					{
						aboutData.quickFacts.map((fact) => (
							<div class="bg-white dark:bg-dark-card rounded-xl p-6 shadow-lg text-center">
								<div class="text-4xl font-bold text-brand-blue mb-2">{fact.value}</div>
								<div class="text-gray-600 dark:text-gray-400">{fact.label}</div>
							</div>
						))
					}
				</div>

				<!-- Journey Highlights -->
				<div
					class="bg-gradient-to-r from-brand-blue/10 to-brand-blue-light/10 dark:from-brand-blue/5 dark:to-transparent rounded-2xl p-8"
					data-reveal
				>
					<h2 class="text-2xl font-bold dark:text-white mb-6">{aboutData.journeyHeading}</h2>
					<div class="space-y-4">
						{
							aboutData.journeyHighlights.map((item) => (
								<div class="flex gap-4">
									<div class="text-brand-blue font-bold min-w-[120px]">{item.date}</div>
									<div class="dark:text-gray-300">{item.description}</div>
								</div>
							))
						}
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
