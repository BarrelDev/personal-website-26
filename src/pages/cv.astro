---
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import { getCollection } from 'astro:content';
import profileData from '../data/profile.json';
import skillsData from '../data/skills.json';
import { PAGES } from '../consts';

const experiences = await getCollection('experience');

const sections = [
	{ id: 'download', label: 'download' },
	{ id: 'education', label: 'education' },
	{ id: 'experience', label: 'experience' },
	{ id: 'skills', label: 'skills' },
	{ id: 'languages', label: 'languages' },
];
---

<BaseLayout title={PAGES.cv.title} description={PAGES.cv.description}>
	<!-- Sidebar Progress Nav -->
	<nav
		id="cv-sidebar"
		class="hidden lg:fixed lg:block right-6 top-1/2 -translate-y-1/2 z-40
			   bg-white/80 dark:bg-dark-card/80 backdrop-blur-md
			   border border-gray-200 dark:border-dark-border
			   rounded-xl px-4 py-3 shadow-lg"
	>
		<ul class="flex flex-col gap-2.5">
			{
				sections.map((s) => (
					<li>
						<a
							href={`#${s.id}`}
							data-cv-link={s.id}
							class="cv-nav-link group flex items-center gap-2.5 text-right transition-all duration-200"
						>
							<span class="text-xs font-medium text-gray-400 dark:text-gray-500 group-hover:text-brand-blue transition-colors">
								{s.label}
							</span>
							<span class="block w-1.5 h-1.5 rounded-full bg-gray-300 dark:bg-gray-600 group-hover:bg-brand-blue transition-all duration-200" />
						</a>
					</li>
				))
			}
		</ul>
	</nav>

	<!-- Header with Download Button -->
	<section id="download" class="pt-10">
		<div class="container mx-auto px-4 text-center">
			<a
				href="/docs/visvam-rajesh-resume.pdf"
				download
				class="inline-flex items-center gap-2 px-8 py-3 bg-brand-blue text-white rounded-lg hover:bg-brand-blue-light transition-all hover:scale-105 shadow-lg"
			>
				<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
					></path>
				</svg>
				Download PDF Resume
			</a>
		</div>
	</section>

	<!-- Education -->
	<section id="education" class="pt-10 py-20">
		<div class="container mx-auto px-4">
			<h2 class="text-3xl font-bold dark:text-white mb-8" data-reveal>education</h2>
			<div class="space-y-6 max-w-4xl">
				{
					profileData.education.map((edu, i) => (
						<div
							data-reveal
							data-reveal-delay={(i + 1).toString()}
							class="bg-white dark:bg-dark-card rounded-xl p-6 shadow-lg border border-gray-200 dark:border-dark-border"
						>
							<div class="flex flex-col sm:flex-row justify-between items-start gap-2">
								<div>
									<h3 class="text-xl font-bold dark:text-white">{edu.institution}</h3>
									<p class="text-brand-blue font-semibold">{edu.degree}</p>
									<p class="text-gray-600 dark:text-gray-400">GPA: {edu.gpa}</p>
								</div>
								<span class="text-gray-500 dark:text-gray-400 whitespace-nowrap">
									{edu.startDate} - {edu.endDate}
								</span>
							</div>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<!-- Experience Timeline -->
	<section id="experience" class="py-16 bg-gray-50 dark:bg-dark-card/50">
		<div class="container mx-auto px-4">
			<h2 class="text-3xl font-bold dark:text-white mb-12" data-reveal>experience</h2>
			<div class="max-w-4xl" data-reveal>
				<ExperienceTimeline experiences={experiences} />
			</div>
		</div>
	</section>

	<!-- Skills -->
	<section id="skills" class="py-16">
		<div class="container mx-auto px-4">
			<h2 class="text-3xl font-bold dark:text-white mb-8" data-reveal>skills</h2>

			<div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
				<!-- Programming Languages -->
				<div
					class="bg-white dark:bg-dark-card rounded-xl p-6 shadow-lg"
					data-reveal
					data-reveal-delay="1"
				>
					<h3 class="text-xl font-bold dark:text-white mb-4">programming languages</h3>
					<div class="flex flex-wrap gap-2">
						{
							skillsData.languages.map((lang) => (
								<span class="px-3 py-2 text-sm rounded-lg border border-brand-blue/30 text-brand-blue font-medium bg-brand-blue/5">
									{lang}
								</span>
							))
						}
					</div>
				</div>

				<!-- Technologies & Frameworks -->
				<div
					class="bg-white dark:bg-dark-card rounded-xl p-6 shadow-lg"
					data-reveal
					data-reveal-delay="2"
				>
					<h3 class="text-xl font-bold dark:text-white mb-4">technologies & frameworks</h3>
					<div class="flex flex-wrap gap-2">
						{
							skillsData.technologies.map((tech) => (
								<span class="px-3 py-2 text-sm rounded-lg border border-brand-blue/30 text-brand-blue font-medium bg-brand-blue/5">
									{tech}
								</span>
							))
						}
					</div>
				</div>

				<!-- Frontend -->
				<div
					class="bg-white dark:bg-dark-card rounded-xl p-6 shadow-lg"
					data-reveal
					data-reveal-delay="1"
				>
					<h3 class="text-xl font-bold dark:text-white mb-4">frontend development</h3>
					<div class="flex flex-wrap gap-2">
						{
							skillsData.categories.frontend.map((tech) => (
								<span class="px-3 py-2 bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 text-sm rounded-lg">
									{tech}
								</span>
							))
						}
					</div>
				</div>

				<!-- Backend -->
				<div
					class="bg-white dark:bg-dark-card rounded-xl p-6 shadow-lg"
					data-reveal
					data-reveal-delay="2"
				>
					<h3 class="text-xl font-bold dark:text-white mb-4">backend development</h3>
					<div class="flex flex-wrap gap-2">
						{
							skillsData.categories.backend.map((tech) => (
								<span class="px-3 py-2 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 text-sm rounded-lg">
									{tech}
								</span>
							))
						}
					</div>
				</div>

				<!-- Robotics -->
				<div
					class="bg-white dark:bg-dark-card rounded-xl p-6 shadow-lg"
					data-reveal
					data-reveal-delay="1"
				>
					<h3 class="text-xl font-bold dark:text-white mb-4">robotics</h3>
					<div class="flex flex-wrap gap-2">
						{
							skillsData.categories.robotics.map((tech) => (
								<span class="px-3 py-2 bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-400 text-sm rounded-lg">
									{tech}
								</span>
							))
						}
					</div>
				</div>

				<!-- ML -->
				<div
					class="bg-white dark:bg-dark-card rounded-xl p-6 shadow-lg"
					data-reveal
					data-reveal-delay="2"
				>
					<h3 class="text-xl font-bold dark:text-white mb-4">machine learning</h3>
					<div class="flex flex-wrap gap-2">
						{
							skillsData.categories.ml.map((tech) => (
								<span class="px-3 py-2 bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-400 text-sm rounded-lg">
									{tech}
								</span>
							))
						}
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Human Languages -->
	<section id="languages" class="pb-16 pt-2">
		<div class="container mx-auto px-4">
			<div class="max-w-5xl mx-auto">
				<div class="bg-white dark:bg-dark-card rounded-xl p-6 shadow-lg" data-reveal>
					<h3 class="text-xl font-bold dark:text-white mb-4">languages</h3>
					<div class="flex flex-wrap gap-3">
						{
							skillsData.human_languages.map((lang) => (
								<span class="px-4 py-2 bg-gray-100 dark:bg-dark-surface rounded-lg text-gray-700 dark:text-gray-300">
									{lang}
								</span>
							))
						}
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<script>
	function initCvSidebar() {
		const sidebar = document.getElementById('cv-sidebar');
		if (!sidebar) return;

		const links = sidebar.querySelectorAll('[data-cv-link]');
		const sectionIds = Array.from(links).map((l) => l.getAttribute('data-cv-link')!);
		const sections = sectionIds
			.map((id) => document.getElementById(id))
			.filter(Boolean) as HTMLElement[];

		if (!sections.length) return;

		let clickedId: string | null = null;

		// Smooth scroll on click — manually set active to handle unreachable sections
		links.forEach((link) => {
			link.addEventListener('click', (e) => {
				e.preventDefault();
				const id = (link as HTMLElement).getAttribute('data-cv-link')!;
				const target = document.getElementById(id);
				if (!target) return;

				// Force-highlight the clicked section immediately
				clickedId = id;
				setActive(id);

				// Scroll to the section
				const navHeight = 80;
				const y = target.getBoundingClientRect().top + window.scrollY - navHeight;
				window.scrollTo({ top: y, behavior: 'smooth' });

				// Release the forced highlight after scroll settles
				setTimeout(() => {
					clickedId = null;
					updateActive();
				}, 800);
			});
		});

		// Scroll spy
		function updateActive() {
			if (clickedId) return; // Don't override while a click-scroll is in progress

			const scrollY = window.scrollY + 150;
			const atBottom = window.innerHeight + window.scrollY >= document.body.scrollHeight - 50;
			let currentId = sectionIds[0];

			// If at the bottom of the page, highlight the last section
			if (atBottom) {
				currentId = sectionIds[sectionIds.length - 1];
			} else {
				for (const section of sections) {
					if (section.offsetTop <= scrollY) {
						currentId = section.id;
					}
				}
			}

			setActive(currentId);
		}

		function setActive(activeId: string) {
			links.forEach((link) => {
				const id = (link as HTMLElement).getAttribute('data-cv-link');
				const label = link.querySelector('span:first-child') as HTMLElement;
				const dot = link.querySelector('span:last-child') as HTMLElement;

				if (id === activeId) {
					label?.classList.remove('text-gray-400', 'dark:text-gray-500');
					label?.classList.add('text-brand-blue', 'dark:text-brand-blue');
					dot?.classList.remove('bg-gray-300', 'dark:bg-gray-600', 'w-1.5', 'h-1.5');
					dot?.classList.add('bg-brand-blue', 'w-2.5', 'h-2.5');
				} else {
					label?.classList.add('text-gray-400', 'dark:text-gray-500');
					label?.classList.remove('text-brand-blue', 'dark:text-brand-blue');
					dot?.classList.add('bg-gray-300', 'dark:bg-gray-600', 'w-1.5', 'h-1.5');
					dot?.classList.remove('bg-brand-blue', 'w-2.5', 'h-2.5');
				}
			});
		}

		window.addEventListener('scroll', updateActive, { passive: true });
		updateActive();
	}

	initCvSidebar();
	document.addEventListener('astro:page-load', initCvSidebar);
</script>
