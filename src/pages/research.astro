---
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicationCard from '../components/PublicationCard.astro';
import { getCollection } from 'astro:content';
import { PAGES } from '../consts';
import researchInterests from '../data/research-interests.json';

const publications = await getCollection('publications');
const sortedPubs = publications.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={PAGES.research.title} description={PAGES.research.description}>
	<!-- Publications List -->
	<section class="py-16">
		<div class="container mx-auto px-4">
			<div class="max-w-4xl mx-auto space-y-8">
				{
					sortedPubs.map((pub) => (
						<div data-reveal>
							<PublicationCard
								title={pub.data.title}
								authors={pub.data.authors}
								venue={pub.data.venue}
								date={pub.data.date}
								abstract={pub.data.abstract}
								pdf={pub.data.pdf}
								doi={pub.data.doi}
								citation={pub.data.citation}
							/>
						</div>
					))
				}
			</div>

			{
				sortedPubs.length === 0 && (
					<div class="text-center text-gray-500 dark:text-gray-400 py-12">
						<p>Publications coming soon!</p>
					</div>
				)
			}
		</div>
	</section>

	<!-- Research Interests -->
	<section class="py-16 bg-gray-50 dark:bg-dark-card/50">
		<div class="container mx-auto px-4">
			<div class="max-w-4xl mx-auto">
				<h2 class="text-3xl font-bold dark:text-white mb-8 text-center" data-reveal>
					Research Interests
				</h2>
				<div class="grid md:grid-cols-2 gap-6">
					{
						researchInterests.map((interest, i) => (
							<div
								class="bg-white dark:bg-dark-card rounded-xl p-6 shadow-lg"
								data-reveal
								data-reveal-delay={(i + 1).toString()}
							>
								<h3 class="text-xl font-bold dark:text-white mb-3">{interest.title}</h3>
								<p class="text-gray-600 dark:text-gray-400">{interest.description}</p>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
