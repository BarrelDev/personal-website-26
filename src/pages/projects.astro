---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Get unique categories
const categories = ['all', ...new Set(projects.map((p) => p.data.category))];
---

<BaseLayout
	title="Projects | Visvam Rajesh"
	description="A collection of my software development, robotics, and machine learning projects."
>
	<!-- Header -->
	<!-- <section
		class="py-10 bg-gradient-to-br from-brand-blue/10 to-brand-blue-light/10 dark:from-brand-blue/5 dark:to-transparent"
	>
		<div class="container mx-auto px-4 text-center">
			<h1 class="text-5xl font-bold dark:text-white mb-4">My Projects</h1>
		</div>
	</section> -->

	<!-- Filters & Grid -->
	<section class="py-16">
		<div class="container mx-auto px-4">
			<!-- Category Filters -->
			<div class="flex flex-wrap justify-center gap-3 mb-12" data-reveal>
				{
					categories.map((category) => (
						<button
							class="filter-btn px-6 py-2 rounded-full border-2 transition-all capitalize
                   hover:border-brand-blue hover:text-brand-blue dark:border-dark-border dark:text-gray-300"
							data-filter={category}
							data-active={category === 'all' ? 'true' : 'false'}
						>
							{category}
						</button>
					))
				}
			</div>

			<!-- Projects Grid -->
			<div id="projects-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
				{
					sortedProjects.map((project, i) => (
						<div class="project-item" data-category={project.data.category} data-reveal data-reveal-delay={((i % 3) + 1).toString()}>
							<ProjectCard
								title={project.data.title}
								description={project.data.description}
								image={project.data.image}
								category={project.data.category}
								tags={project.data.tech}
								github={project.data.github}
								demo={project.data.demo}
								featured={project.data.featured}
							/>
						</div>
					))
				}
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.filter-btn[data-active='true'] {
		@apply bg-brand-blue text-white border-brand-blue;
	}

	.project-item {
		transition: opacity 0.3s ease, transform 0.3s ease;
	}

	.project-item.hiding {
		opacity: 0;
		transform: scale(0.97) translateY(6px);
	}

	.project-item.showing {
		opacity: 1;
		transform: scale(1) translateY(0);
	}

	.project-item.hidden-item {
		display: none;
	}
</style>

<!-- Filter functionality -->
<script>
	function setupFilters() {
		const filterButtons = document.querySelectorAll('.filter-btn');
		const projectItems = document.querySelectorAll('.project-item');
		let animating = false;

		filterButtons.forEach((btn) => {
			btn.addEventListener('click', () => {
				if (animating) return; // Block clicks during animation
				const filter = btn.getAttribute('data-filter');

				// Update active button
				filterButtons.forEach((b) => b.setAttribute('data-active', 'false'));
				btn.setAttribute('data-active', 'true');

				// Sort items into hide/show groups
				const toHide: HTMLElement[] = [];
				const toShow: HTMLElement[] = [];

				projectItems.forEach((item) => {
					const category = item.getAttribute('data-category');
					const el = item as HTMLElement;
					const matches = filter === 'all' || category === filter;

					if (matches) {
						toShow.push(el);
					} else if (!el.classList.contains('hidden-item')) {
						toHide.push(el);
					}
				});

				animating = true;

				// Phase 1: fade out all currently visible non-matching items
				if (toHide.length > 0) {
					toHide.forEach((el) => {
						el.classList.remove('showing');
						el.classList.add('hiding');
					});

					// Wait for the longest fade-out to finish (300ms transition)
					setTimeout(() => {
						toHide.forEach((el) => {
							el.classList.add('hidden-item');
							el.classList.remove('hiding');
						});
						// Phase 2: stagger fade in matching items
						revealItems(toShow);
					}, 320);
				} else {
					// Nothing to hide, go straight to reveal
					revealItems(toShow);
				}

				function revealItems(items: HTMLElement[]) {
					// Prepare: make all matching items visible but invisible
					items.forEach((el) => {
						el.classList.remove('hidden-item', 'showing');
						el.classList.add('hiding');
					});

					// Force reflow so browsers register the initial state
					void document.body.offsetHeight;

					// Stagger each item's fade-in
					items.forEach((el, i) => {
						setTimeout(() => {
							el.classList.remove('hiding');
							el.classList.add('showing');
						}, i * 60);
					});

					// Unlock after all animations complete
					const totalTime = items.length * 60 + 300;
					setTimeout(() => {
						animating = false;
					}, totalTime);
				}
			});
		});

		// Initialize all as showing
		projectItems.forEach((el) => {
			(el as HTMLElement).classList.add('showing');
		});
	}

	setupFilters();
	document.addEventListener('astro:page-load', setupFilters);
</script>
